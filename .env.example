# ==========================================
# iGaming Brand Protection Platform
# Environment Configuration
# ==========================================

# API Keys for External Services
# --------------------------------

# Twitter/X API for social media monitoring
TWITTER_API_KEY=your_twitter_bearer_token_here

# VirusTotal for malware detection
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# URLVoid for URL reputation
URLVOID_API_KEY=your_urlvoid_api_key_here

# Shodan for infrastructure analysis
SHODAN_API_KEY=your_shodan_api_key_here

# SecurityTrails for passive DNS
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# Telegram Alerts (Optional)
# --------------------------------
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here
ENABLE_TG_ALERT=0

# Dashboard Security (Optional)
# --------------------------------
DASHBOARD_SECRET=your_secure_dashboard_secret_here

# Server Configuration
# --------------------------------
PORT=3000
NODE_ENV=production

# Database Configuration
# --------------------------------
DB_PATH=./data/monitor.db

# Monitoring Configuration
# --------------------------------
DEFAULT_SCAN_CONCURRENCY=50
MAX_DOMAINS_PER_SCAN=500
VISUAL_ANALYSIS_TIMEOUT=30000